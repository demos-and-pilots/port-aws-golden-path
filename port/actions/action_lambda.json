{
  "identifier": "deploy_aws_lambda",
  "title": "Desplegar Lambda Function en AWS (dentro de VPC)",
  "icon": "AWS",
  "description": "Crea una Lambda Function con su IAM Role, deployment package desde S3, configuración de VPC (subnets y security groups), variables de entorno y dead-letter queue. Solo configura variables.",
  "trigger": {
    "type": "self-service",
    "operation": "CREATE",
    "userInputs": {
      "properties": {
        "awsAccountId": {
          "type": "string",
          "title": "AWS Account ID",
          "pattern": "^[0-9]{12}$"
        },
        "awsRegion": {
          "type": "string",
          "title": "Región AWS",
          "enum": [
            "us-east-1", "us-east-2", "us-west-1", "us-west-2",
            "eu-west-1", "eu-west-2", "eu-central-1",
            "ap-southeast-1", "ap-southeast-2", "sa-east-1"
          ],
          "default": "us-east-1"
        },
        "environment": {
          "type": "string",
          "title": "Entorno",
          "enum": ["dev", "staging", "prod"],
          "default": "dev"
        },
        "projectName": {
          "type": "string",
          "title": "Nombre de la función",
          "description": "Sin espacios ni caracteres especiales",
          "pattern": "^[a-z][a-z0-9-]{2,50}$"
        },
        "runtime": {
          "type": "string",
          "title": "Runtime",
          "enum": [
            "python3.12", "python3.11", "python3.10",
            "nodejs20.x", "nodejs18.x",
            "java21", "java17", "java11",
            "dotnet8", "provided.al2023"
          ],
          "default": "python3.12"
        },
        "handler": {
          "type": "string",
          "title": "Handler",
          "description": "Punto de entrada. Ej: index.handler para Node, lambda_function.lambda_handler para Python",
          "default": "lambda_function.lambda_handler"
        },
        "memorySizeMb": {
          "type": "number",
          "title": "Memoria (MB)",
          "description": "Entre 128 MB y 10240 MB",
          "default": 256,
          "enum": [128, 256, 512, 1024, 2048, 3008, 4096, 8192, 10240]
        },
        "timeoutSeconds": {
          "type": "number",
          "title": "Timeout (segundos)",
          "description": "Máximo 900 segundos (15 minutos)",
          "default": 30
        },
        "s3BucketCode": {
          "type": "string",
          "title": "S3 Bucket del código",
          "description": "Bucket donde está el .zip del deployment package"
        },
        "s3KeyCode": {
          "type": "string",
          "title": "S3 Key del código",
          "description": "Path al .zip dentro del bucket. Ej: releases/my-function-v1.0.zip",
          "default": "releases/function.zip"
        },
        "vpcId": {
          "type": "string",
          "title": "VPC ID",
          "description": "ID de la VPC donde se desplegará la Lambda (ej: vpc-0abc1234)"
        },
        "subnetIds": {
          "type": "string",
          "title": "Subnet IDs (separados por coma)",
          "description": "Subnets PRIVADAS de la VPC. Ej: subnet-aaa,subnet-bbb"
        },
        "enableDlq": {
          "type": "boolean",
          "title": "Habilitar Dead-Letter Queue (SQS)",
          "description": "Captura invocaciones fallidas para análisis posterior",
          "default": false
        },
        "envVars": {
          "type": "string",
          "title": "Variables de entorno (formato KEY=VALUE,KEY2=VALUE2)",
          "description": "Ej: DB_TABLE=mi-tabla,LOG_LEVEL=INFO"
        },
        "ownerTeam": {
          "type": "string",
          "title": "Equipo responsable"
        },
        "costCenter": {
          "type": "string",
          "title": "Centro de costos"
        }
      },
      "required": ["awsAccountId", "awsRegion", "projectName", "environment", "runtime", "handler", "s3BucketCode", "s3KeyCode", "vpcId", "subnetIds", "ownerTeam"]
    }
  },
    "invocationMethod": {
    "type": "INTEGRATION_ACTION",
    "installationId": "github-port-demos",
    "integrationActionType": "dispatch_workflow",
    "integrationActionExecutionProperties": {
      "org": "demos-and-pilots",
      "repo": "port-aws-golden-path",
      "workflow": "deploy-aws-resource.yml",
      "workflowInputs": {
        "port_context": {
          "runId": "{{ .run.id }}",
          "blueprint": "aws_resource",
          "inputs": "{{ .inputs }}",
          "resourceType": "Lambda"
        }
      },
      "reportWorkflowStatus": true
    }
  },
  "allowAnyoneToViewRuns": true,
  "requiredApproval": false
}
